//@version=5
strategy("UT Bot Institutional ELITE (ES 1h)", shorttitle="UT Bot ELITE (ES)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=5)

// ============================================================================
// INSTITUTIONAL UT BOT ELITE - Professional Grade with Advanced Confluence
// Features: Fibonacci entries, Multi-confirmation, Trend strength, Drawdown protection
// ============================================================================

// FIBONACCI CONSTANTS
PHI = 1.618034
FRAC_618 = 0.618
FRAC_786 = 0.786
FRAC_272 = 1.272
FRAC_162 = 1.618

// INPUT SETTINGS
key_value = input.float(1.0, "Key Value (ATR Multiplier)", minval=0.1, maxval=5.0, step=0.1)
atr_period = input.int(10, "ATR Period", minval=1, maxval=50)
min_rr = input.float(1.618, "Min Risk/Reward Ratio (Golden)", minval=1.0, maxval=3.0, step=0.1)
min_confluence = input.int(3, "Min Confluence Signals (3-6, higher=stricter)", minval=1, maxval=6)
use_fibonacci_entry = input.bool(true, "Use Fibonacci RTM Entry")
use_volume_filter = input.bool(true, "Require Volume Confirmation")
volume_mult = input.float(1.5, "Volume Multiplier (ES=1.5)")
enable_drawdown_protection = input.bool(true, "Enable Drawdown Protection")
max_loss_percent = input.float(2.0, "Max Daily Loss % (Protection)", minval=0.5, maxval=10.0)
session_filter = input.bool(true, "Filter Pre-Market/Post-Market (9:30-16:00 EST)")

// COLORS
col_buy = input.color(color.green, "Buy Color")
col_sell = input.color(color.red, "Sell Color")
col_trail = input.color(color.orange, "Trailing Stop Color")

// ============================================================================
// CORE CALCULATIONS
// ============================================================================

atr_val = ta.atr(atr_period)
loss_amount = key_value * atr_val
src = close

// EMAs for trend confirmation (9, 20, 50)
ema_fast = ta.ema(close, 9)
ema_mid = ta.ema(close, 20)
ema_slow = ta.ema(close, 50)
sma_20 = ta.sma(close, 20)

// Momentum indicators
rsi = ta.rsi(close, 14)
macd_line = ta.ema(close, 12) - ta.ema(close, 26)
macd_signal = ta.ema(macd_line, 9)

// Volume & Volatility
vol_avg = ta.sma(volume, 20)
volume_ok = use_volume_filter ? volume > vol_avg * volume_mult : true
atr_pct = (atr_val / close) * 100
volatility_ok = atr_pct >= 0.20

// Session filtering (EST)
in_session = session.ismarket ? true : false
safe_session = session_filter ? in_session : true

// Drawdown protection
var cumulative_loss = 0.0
protected_mode = enable_drawdown_protection ? cumulative_loss >= (strategy.initial_capital * max_loss_percent / 100) : false

// ============================================================================
// SWING & FIBONACCI DETECTION
// ============================================================================

f_recent_swing_high() =>
    result = high
    for i = 1 to 20
        if high[i] == ta.highest(high[i], i * 2 + 1)
            result := high[i]
    result

f_recent_swing_low() =>
    result = low
    for i = 1 to 20
        if low[i] == ta.lowest(low[i], i * 2 + 1)
            result := low[i]
    result

f_fib_retracement(swing_h, swing_l, ratio) =>
    swing_range = swing_h - swing_l
    swing_h - (swing_range * ratio)

// ============================================================================
// TREND STRENGTH SCORING (Institutional Quality Check)
// ============================================================================

f_trend_strength() =>
    score = 0
    // EMA alignment (bullish/bearish stacking)
    if ema_fast > ema_mid and ema_mid > ema_slow
        score := score + 2
    else if ema_fast < ema_mid and ema_mid < ema_slow
        score := score - 2
    
    // Price above/below key EMAs
    if close > ema_slow
        score := score + 1
    else if close < ema_slow
        score := score - 1
    
    // RSI confirmation (not overbought/oversold)
    if rsi > 50 and rsi < 70
        score := score + 1
    else if rsi < 50 and rsi > 30
        score := score + 1
    
    // MACD confirmation
    if macd_line > macd_signal
        score := score + 1
    else if macd_line < macd_signal
        score := score - 1
    
    score

// ============================================================================
// CONFLUENCE SCORING (6-Signal System from Phase 2)
// ============================================================================

f_confluence_score() =>
    score = 1  // Base score
    
    // 1. Volume confirmation
    if volume_ok
        score := score + 1
    
    // 2. Trend strength
    trend = f_trend_strength()
    if trend >= 2
        score := score + 1
    
    // 3. RSI in optimal zone
    if (rsi > 40 and rsi < 60)
        score := score + 1
    
    // 4. EMA alignment
    if (ema_fast > ema_mid > ema_slow) or (ema_fast < ema_mid < ema_slow)
        score := score + 1
    
    // 5. MACD confirmation
    if macd_line > macd_signal
        score := score + 1
    // OR
    if macd_line < macd_signal
        score := score + 1
    
    // 6. Volatility normal (not too spiky)
    if volatility_ok
        score := score + 1
    
    score

// ============================================================================
// TRAILING STOP LOGIC (UT Bot Core)
// ============================================================================

var trailing_stop = 0.0
var position = 0

if src > nz(trailing_stop[1], 0) and src[1] > nz(trailing_stop[1], 0)
    trailing_stop := math.max(nz(trailing_stop[1]), src - loss_amount)
else if src < nz(trailing_stop[1], 0) and src[1] < nz(trailing_stop[1], 0)
    trailing_stop := math.min(nz(trailing_stop[1]), src + loss_amount)
else if src > nz(trailing_stop[1], 0)
    trailing_stop := src - loss_amount
else
    trailing_stop := src + loss_amount

// Position tracking
if src[1] < nz(trailing_stop[1], 0) and src > nz(trailing_stop[1], 0)
    position := 1
else if src[1] > nz(trailing_stop[1], 0) and src < nz(trailing_stop[1], 0)
    position := -1

// ============================================================================
// CROSSOVER DETECTION & INSTITUTIONAL FILTERS
// ============================================================================

// EMA1 vs Trailing Stop crossover
ema_val = ta.ema(src, 1)
above = ta.crossover(ema_val, trailing_stop)
below = ta.crossover(trailing_stop, ema_val)

buy_basic = src > trailing_stop and above
sell_basic = src < trailing_stop and below

// Get confidence score
confluence = f_confluence_score()

// Institutional filtering
buy_filtered = buy_basic and volume_ok and volatility_ok and confluence >= min_confluence and safe_session and not protected_mode
sell_filtered = sell_basic and volume_ok and volatility_ok and confluence >= min_confluence and safe_session and not protected_mode

// ============================================================================
// FIBONACCI ENTRY REFINEMENT & RISK/REWARD CALCULATION
// ============================================================================

// Get swing points for Fibonacci refinement
swing_h = f_recent_swing_high()
swing_l = f_recent_swing_low()
swing_range = swing_h - swing_l

// Fibonacci entry levels (Retracement to 0.618)
fib_entry_bull = f_fib_retracement(swing_h, swing_l, FRAC_618)
fib_entry_bear = swing_h + (swing_range * FRAC_618)

// For BUY: Use Fibonacci entry or current price (whichever closer to stop)
buy_entry = use_fibonacci_entry ? fib_entry_bull : src
buy_sl = trailing_stop
buy_sl_dist = math.abs(buy_entry - buy_sl)

// Fibonacci targets (1.272x and 1.618x risk multipliers = golden ratio)
buy_target_1 = buy_entry + (buy_sl_dist * FRAC_272)  // 1.272x
buy_target_2 = buy_entry + (buy_sl_dist * FRAC_162)  // 1.618x (primary)
buy_target_3 = buy_entry + (buy_sl_dist * FRAC_261)  // 2.618x (expansion)

buy_rr = buy_sl_dist > 0 ? (buy_target_2 - buy_entry) / buy_sl_dist : 0

// For SELL: Use Fibonacci entry or current price
sell_entry = use_fibonacci_entry ? fib_entry_bear : src
sell_sl = trailing_stop
sell_sl_dist = math.abs(sell_entry - sell_sl)

// Fibonacci targets for SELL
sell_target_1 = sell_entry - (sell_sl_dist * FRAC_272)
sell_target_2 = sell_entry - (sell_sl_dist * FRAC_162)
sell_target_3 = sell_entry - (sell_sl_dist * FRAC_261)

sell_rr = sell_sl_dist > 0 ? (sell_entry - sell_target_2) / sell_sl_dist : 0

// Confidence calculation (60 base + 8 per confluence signal)
f_confidence(conf_score) =>
    math.round(60.0 + (conf_score * 8.0))

confidence = f_confidence(confluence)

// ============================================================================
// FINAL SIGNAL VALIDATION (INSTITUTIONAL - ALL CRITERIA MUST ALIGN)
// ============================================================================

buy_signal = buy_filtered and buy_rr >= min_rr
sell_signal = sell_filtered and sell_rr >= min_rr

// Track losses for drawdown protection
if strategy.closedtrades > 0
    cumulative_loss := strategy.netprofit

// ============================================================================
// STRATEGY ENTRIES & EXITS (With Fibonacci Targets)
// ============================================================================

if buy_signal and strategy.position_size == 0
    strategy.entry("BUY", strategy.long, comment="UT Elite Buy")
    
if sell_signal and strategy.position_size == 0
    strategy.entry("SELL", strategy.short, comment="UT Elite Sell")

// Multi-level exits with trailing
if strategy.position_size > 0
    strategy.exit("TP2", "BUY", limit=buy_target_2, stop=buy_sl)
    
if strategy.position_size < 0
    strategy.exit("TP2", "SELL", limit=sell_target_2, stop=sell_sl)

// ============================================================================
// VISUALIZATION (Enhanced)
// ============================================================================

// Trailing stop
plot(trailing_stop, "Trailing Stop", color=col_trail, linewidth=2)

// EMA confirmation
ema_1_plot = ta.ema(src, 1)
plot(ema_1_plot, "EMA(1)", color=color.blue, linewidth=1)

// Major EMAs for trend context
plot(ema_fast, "EMA(9)", color=color.new(color.orange, 60), linewidth=1)
plot(ema_mid, "EMA(20)", color=color.new(color.yellow, 60), linewidth=1)

// Buy/Sell signals
plotshape(buy_signal, style=shape.labelup, location=location.belowbar, color=col_buy, size=size.small, text="BUY")
plotshape(sell_signal, style=shape.labeldown, location=location.abovebar, color=col_sell, size=size.small, text="SELL")

// Bar coloring (yellow = high confluence, green/red = signal)
bar_col = buy_basic ? color.new(color.green, 80) : sell_basic ? color.new(color.red, 80) : na
barcolor(bar_col)

// ============================================================================
// PROFESSIONAL ALERTS (With Full Metrics)
// ============================================================================

if buy_signal
    alert("UT ELITE BUY | Confluence: " + str.tostring(confluence) + "/6 | Confidence: " + str.tostring(confidence) + "% | RR: " + str.tostring(math.round(buy_rr, 2)) + ":1 | Entry: " + str.tostring(math.round(buy_entry, 2)) + " | SL: " + str.tostring(math.round(buy_sl, 2)) + " | TP: " + str.tostring(math.round(buy_target_2, 2)))

if sell_signal
    alert("UT ELITE SELL | Confluence: " + str.tostring(confluence) + "/6 | Confidence: " + str.tostring(confidence) + "% | RR: " + str.tostring(math.round(sell_rr, 2)) + ":1 | Entry: " + str.tostring(math.round(sell_entry, 2)) + " | SL: " + str.tostring(math.round(sell_sl, 2)) + " | TP: " + str.tostring(math.round(sell_target_2, 2)))
