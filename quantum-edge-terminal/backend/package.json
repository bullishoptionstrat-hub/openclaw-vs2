{
  "name": "quantum-edge-backend",
  "version": "1.0.0",
  "description": "Production-grade institutional trading platform backend",
  "main": "src/server.ts",
  "type": "module",
  "scripts": {
    "dev": "node --loader ts-node/esm src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "express-ws": "^5.0.2",
    "pg": "^8.11.3",
    "redis": "^4.6.13",
    "jsonwebtoken": "^9.1.2",
    "dotenv": "^16.4.5",
    "zod": "^3.23.0",
    "pino": "^8.17.2",
    "ws": "^8.15.1",
    "axios": "^1.7.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/express": "^4.17.21",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "vitest": "^1.1.0",
    "prettier": "^3.1.1",
    "eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
